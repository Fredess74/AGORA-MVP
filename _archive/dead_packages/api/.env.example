# Agora Database Configuration

# Development database (local PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agora_dev

# Redis cache
REDIS_URL=redis://localhost:6379

# Server configuration
AGORA_HOST=0.0.0.0
AGORA_PORT=8080

# Rate limiting
AGORA_RATE_LIMIT_RPS=100
AGORA_RATE_LIMIT_BURST=50

# Trust engine
AGORA_MIN_EVENTS=10
