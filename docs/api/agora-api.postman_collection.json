{
    "info": {
        "name": "Agora Trust API",
        "description": "Agora Trust Protocol API Collection",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "auth": {
        "type": "apikey",
        "apikey": [
            {
                "key": "key",
                "value": "X-Agora-Key",
                "type": "string"
            },
            {
                "key": "value",
                "value": "{{api_key}}",
                "type": "string"
            },
            {
                "key": "in",
                "value": "header",
                "type": "string"
            }
        ]
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8080"
        },
        {
            "key": "api_key",
            "value": "agora_test_key_12345"
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "Health Check",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/v1/health"
                    }
                },
                {
                    "name": "Metrics",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/v1/metrics"
                    }
                }
            ]
        },
        {
            "name": "Agents",
            "item": [
                {
                    "name": "Register Agent",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/v1/agents/register",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"public_key\": \"a1b2c3d4e5f6789012345678901234567890123456789012345678901234abcd\",\n  \"agent_type\": \"api\",\n  \"metadata\": {\n    \"name\": \"Test Agent\",\n    \"version\": \"1.0.0\"\n  }\n}"
                        }
                    }
                },
                {
                    "name": "Get Agent",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/v1/agents/did:agora:example123"
                    }
                }
            ]
        },
        {
            "name": "Events",
            "item": [
                {
                    "name": "Report Event",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/v1/events/report",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"agent_did\": \"did:agora:agent1\",\n  \"counterparty_did\": \"did:agora:agent2\",\n  \"outcome\": \"success\",\n  \"latency_ms\": 150,\n  \"amount_cents\": 500\n}"
                        }
                    }
                },
                {
                    "name": "List Events",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/v1/events?agent_did=did:agora:example&limit=10",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "v1",
                                "events"
                            ],
                            "query": [
                                {
                                    "key": "agent_did",
                                    "value": "did:agora:example"
                                },
                                {
                                    "key": "limit",
                                    "value": "10"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Trust",
            "item": [
                {
                    "name": "Get Trust Score",
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/v1/trust/did:agora:example"
                    }
                },
                {
                    "name": "Batch Trust Query",
                    "request": {
                        "method": "POST",
                        "url": "{{base_url}}/v1/trust/batch",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"dids\": [\n    \"did:agora:agent1\",\n    \"did:agora:agent2\",\n    \"did:agora:agent3\"\n  ]\n}"
                        }
                    }
                }
            ]
        }
    ]
}